# Server Environment Variables
# Copy to .env and fill in your values

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/vaultgames"
MONGODB_URI="mongodb://localhost:27017/vaultgames"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="your-super-secret-access-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email (use Resend or Gmail SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="VaultGames <noreply@vaultgames.gg>"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Anthropic AI
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"

# OTP Config
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
